---
import Layout from '../layouts/Layout.astro';
import ContactCard from '../components/ContactCard.astro';
import BriefcaseBusiness from '@lucide/astro/icons/briefcase-business';
import FolderGit2 from '@lucide/astro/icons/folder-git-2';
import GraduationCap from '@lucide/astro/icons/graduation-cap';
import Landmark from '@lucide/astro/icons/landmark';
import Mail from '@lucide/astro/icons/mail';
import MessageCircle from '@lucide/astro/icons/message-circle';
import Phone from '@lucide/astro/icons/phone';
import ShieldCheck from '@lucide/astro/icons/shield-check';

const profile = {
	name: 'Erik Engler',
	age: 22,
	role: 'Informatik-Student & Hochschulpolitiker',
	intro: 'Persönliches Profil',
	summary:
		'Ich studiere Informatik, weil ich gerne verstehe, wie die Welt von morgen funktioniert. Am liebsten aber bin ich mitten im Geschehen: Als Mitglied im StuRa und FSR bin ich eure Stimme am Campus. Mir ist wichtig, dass wir gemeinsam eine gute Zeit haben und etwas bewirken. Hier findest du alle Wege, wie wir in Kontakt bleiben können. Ich freu mich von dir zu hören!',
	badges: ['Angewandte Informatik', 'Studierendenrat', 'Fachschaftsrat'],
};

const portrait = {
	src: '/erik-portrait.png',
	alt: 'Portrait von Erik Engler',
	title: 'Zuverlässigkeit ist für mich die Basis, Begeisterung der Antrieb.',
	description:
		'Ich schätze klare Strukturen und einen professionellen Austausch, verliere dabei aber nie den Blick für die Menschen dahinter.',
};

const highlights = [
	{
		label: 'Studium',
		value: 'Angewandte Informatik',
		description:
			'Im Studium der Angewandten Informatik fasziniert mich vor allem die Verbindung aus Logik und Praxis. Es geht mir nicht nur um Code, sondern darum, wie wir Technik nutzen können, um echte Probleme zu lösen und den Alltag ein Stück einfacher zu machen.',
		icon: GraduationCap,
	},
	{
		label: 'Engagement',
		value: 'StuRa & FSR',
		description:
			'Hochschulpolitik bedeutet für mich vor allem: Zuhören und Mitgestalten. Im StuRa und FSR setze ich mich dafür ein, dass wir als Studierende eine starke Stimme haben. Mir macht es Freude, Dinge gemeinsam zu organisieren und Verantwortung für eine lebendige Campus-Gemeinschaft zu übernehmen.',
		icon: Landmark,
	},
	{
		label: 'Arbeitsweise',
		value: 'Strukturiert & Verlässlich',
		description:
			'Ich mag es, wenn Dinge funktionieren. Dabei ist mir eine ruhige und klare Kommunikation genauso wichtig wie ein Ergebnis, auf das man sich verlassen kann. Ich arbeite gerne strukturiert, verliere dabei aber nie die Menschen aus dem Blick, für die ich ein Projekt umsetze.',
		icon: ShieldCheck,
	},
];

// Zentrale Stelle für alle später anpassbaren Kontakt- und Profil-Links.
const contacts = [
	{
		title: 'Hochschul-Email',
		value: 'erik.engler@student.hs-anhalt.de',
		href: 'mailto:erik.engler@student.hs-anhalt.de',
		icon: Mail,
		description: 'Für Hochschule, Gremienarbeit und offizielle Anfragen.',
		external: false,
	},
	{
		title: 'Business-Mail',
		value: 'hey@erikengler.pro',
		href: 'mailto:hey@erikengler.pro',
		icon: Mail,
		description: 'Für berufliche Anfragen, Projekte und Kooperationen.',
		external: false,
	},
	{
		title: 'Telefon',
		value: '+49 151 10481071',
		href: 'tel:+4915110481071',
		icon: Phone,
		description: 'Direkter Kontakt für schnelle Abstimmungen.',
		external: false,
	},
	{
		title: 'WhatsApp',
		value: 'wa.me/4915110481071',
		href: 'https://wa.me/4915110481071',
		icon: MessageCircle,
		description: 'Schnell erreichbar unter derselben Nummer.',
		external: true,
	},
	{
		title: 'LinkedIn',
		value: 'linkedin.com/in/erikengler',
		href: 'https://www.linkedin.com/in/erikengler',
		icon: BriefcaseBusiness,
		description: 'Professionelles Profil für Netzwerk und Karriere.',
		external: true,
	},
	{
		title: 'GitHub',
		value: 'github.com/erikenglerdev',
		href: 'https://github.com/erikenglerdev',
		icon: FolderGit2,
		description: 'Code, Experimente und technische Projekte.',
		external: true,
	},
];
---

<Layout
	title="Erik Engler | Informatik-Student & Hochschulpolitiker"
	description="Landing Page von Erik Engler mit Fokus auf Studium, Engagement und einen modernen Business-Auftritt."
>
	<main class="relative">
		<div class="mx-auto flex min-h-screen w-full max-w-7xl flex-col px-6 pb-20 pt-6 sm:px-8 lg:px-10">
			<header class="sticky top-3 z-20">
				<div class="flex items-center justify-between gap-4 rounded-full border border-[var(--color-border)] bg-white/88 px-5 py-3 shadow-[0_12px_28px_rgba(24,33,43,0.06)] backdrop-blur">
					<div class="flex items-center">
						<div>
							<p class="text-sm font-semibold text-[var(--color-text)]">{profile.name}</p>
							<p class="text-xs font-medium uppercase tracking-[0.14em] text-[var(--color-muted)]">
								{profile.role}
							</p>
						</div>
					</div>
					<div class="flex items-center gap-2">
						<a
							href="#kontakt"
							class="hidden rounded-full px-4 py-2 text-sm text-[var(--color-muted)] hover:text-[var(--color-text)] sm:inline-flex"
						>
							Kontakt
						</a>
					</div>
				</div>
			</header>

			<section class="pt-5">
				<div class="grid gap-6 rounded-[2.4rem] border border-[var(--color-border)] bg-white p-5 shadow-[0_24px_60px_rgba(24,33,43,0.06)] lg:grid-cols-[minmax(0,1.18fr)_320px] lg:items-stretch lg:gap-6 lg:p-6">
					<div class="max-w-4xl lg:flex lg:h-full lg:flex-col lg:pr-4">
						<div>
							<div class="inline-flex rounded-full border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-2 text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-[var(--color-muted)]">
								{profile.intro}
							</div>
							<h1 class="mt-5 max-w-4xl text-5xl font-semibold tracking-[-0.065em] text-balance text-[var(--color-text)] sm:text-6xl lg:text-[4.2rem]">
								{profile.name}
								<span class="mt-3 block max-w-2xl text-[0.5em] font-medium leading-tight tracking-[-0.04em] text-[var(--color-muted)]">
									{profile.role}
								</span>
							</h1>
							<p class="mt-5 max-w-2xl text-lg leading-8 text-[var(--color-muted)] sm:text-[1.05rem]">
								{profile.summary}
							</p>
						</div>

						<div class="mt-7 grid gap-4 md:grid-cols-3 lg:min-h-0 lg:flex-1">
							{highlights.map(({ label, value, description, icon: Icon }) => (
								<article class="flex h-full flex-col rounded-[1.8rem] border border-[var(--color-border)] bg-[var(--color-surface-strong)] p-5 shadow-[0_14px_28px_rgba(24,33,43,0.04)]">
									<div class="flex size-12 items-center justify-center rounded-[1.25rem] bg-[color:var(--color-accent-soft)] text-[color:var(--color-accent-strong)]">
										<Icon class="size-5" strokeWidth={1.8} />
									</div>
									<p class="mt-5 text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-[var(--color-muted)]">
										{label}
									</p>
									<h2 class="mt-2 text-lg font-semibold tracking-[-0.03em] text-[var(--color-text)]">
										{value}
									</h2>
									<p class="mt-3 text-sm leading-6 text-[var(--color-muted)]">{description}</p>
								</article>
							))}
						</div>
					</div>

					<aside class="grid gap-4 lg:h-full lg:grid-rows-[minmax(0,1fr)_auto]">
						<div class="flex h-full flex-col rounded-[2rem] border border-[var(--color-border)] bg-[var(--color-surface)] p-4 shadow-[0_18px_46px_rgba(24,33,43,0.07)]">
							<div class="h-full overflow-hidden rounded-[1.6rem] bg-[var(--color-image-frame)]">
								<img
									src={portrait.src}
									alt={portrait.alt}
									class="h-full min-h-[360px] w-full object-cover object-center"
									loading="eager"
								/>
							</div>
						</div>

						<div class="rounded-[1.7rem] border border-[var(--color-border)] bg-[var(--color-surface-subtle)] p-5">
							<p class="text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-[var(--color-muted)]">
							Persönlicher Eindruck
							</p>
							<h2 class="mt-3 text-xl font-semibold tracking-[-0.04em] text-[var(--color-text)]">
								{portrait.title}
							</h2>
							<p class="mt-3 text-sm leading-6 text-[var(--color-muted)]">{portrait.description}</p>
						</div>
					</aside>
				</div>
			</section>

			<section id="kontakt" class="scroll-mt-28 pt-12">
				<div class="rounded-[2.2rem] border border-[var(--color-border)] bg-white p-5 shadow-[0_18px_46px_rgba(24,33,43,0.05)] sm:p-6 lg:p-7">
					<p class="text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-[var(--color-muted)]">
						Kontakt
					</p>

					<div class="mt-5 grid gap-3 sm:grid-cols-2 xl:grid-cols-3">
						{contacts.map((contact) => (
							<ContactCard {...contact} />
						))}
					</div>
				</div>
			</section>

			<footer class="mt-auto pt-14">
				<div class="flex flex-col items-center gap-3 border-t border-[var(--color-border)] py-6 text-center text-sm text-[var(--color-muted)]">
					<p>{profile.name} | Student der Angewandten Informatik | StuRa & FSR</p>
				</div>
			</footer>
		</div>
	</main>
</Layout>
