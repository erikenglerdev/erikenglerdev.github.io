---
import ArrowUpRight from '@lucide/astro/icons/arrow-up-right';

interface Props {
	title: string;
	value: string;
	href: string;
	icon: any;
	description?: string;
	external?: boolean;
}

const {
	title,
	value,
	href,
	icon: Icon,
	description,
	external = false,
} = Astro.props;

const linkProps = external
	? {
			target: '_blank',
			rel: 'noreferrer noopener',
		}
	: {};
---

<a
	href={href}
	{...linkProps}
	aria-label={`${title}: ${value}`}
	class="group flex h-full items-start gap-4 rounded-[1.35rem] border border-[var(--color-border)] bg-[var(--color-surface-strong)] p-4 shadow-[0_10px_22px_rgba(24,33,43,0.04)] hover:-translate-y-0.5 hover:border-[color:var(--color-accent)]/24 hover:shadow-[0_18px_30px_rgba(24,33,43,0.06)]"
>
	<div class="flex size-12 shrink-0 items-center justify-center rounded-[1rem] border border-[color:var(--color-accent)]/12 bg-[color:var(--color-accent-soft)] text-[color:var(--color-accent-strong)]">
		<Icon class="size-5" strokeWidth={1.8} />
	</div>

	<div class="min-w-0 flex-1">
		<div class="flex items-start justify-between gap-3">
			<p class="text-[0.7rem] font-semibold uppercase tracking-[0.18em] text-[var(--color-muted)]">
				{title}
			</p>
			<div class="mt-0.5 inline-flex items-center gap-1 text-[0.7rem] font-semibold text-[var(--color-muted)]">
				{external ? 'Extern' : 'Direkt'}
				{external && <ArrowUpRight class="size-3.5 transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5" strokeWidth={1.8} />}
			</div>
		</div>
		<p class="mt-2 text-base font-semibold tracking-[-0.02em] break-words text-[var(--color-text)]">
			{value}
		</p>
		{description && <p class="mt-2 text-sm leading-5 text-[var(--color-muted)]">{description}</p>}
	</div>
</a>
