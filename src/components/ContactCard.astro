---
import ArrowRight from '@lucide/astro/icons/arrow-right';
import ArrowUpRight from '@lucide/astro/icons/arrow-up-right';

interface Props {
	title: string;
	value: string;
	href: string;
	icon: any;
	description?: string;
	external?: boolean;
}

const {
	title,
	value,
	href,
	icon: Icon,
	description,
	external = false,
} = Astro.props;

const linkProps = external
	? {
			target: '_blank',
			rel: 'noreferrer noopener',
		}
	: {};
---

<a
	href={href}
	{...linkProps}
	aria-label={`${title}: ${value}`}
	class="group flex h-full items-center gap-4 rounded-[1.5rem] border border-[var(--color-border)] bg-[var(--color-surface-strong)] px-4 py-4 shadow-[0_8px_20px_rgba(24,33,43,0.04)] hover:-translate-y-0.5 hover:border-[color:var(--color-accent)]/26 hover:shadow-[0_16px_30px_rgba(24,33,43,0.07)]"
>
	<div class="flex size-12 shrink-0 items-center justify-center rounded-[1rem] border border-[color:var(--color-accent)]/12 bg-[color:var(--color-accent-soft)] text-[color:var(--color-accent-strong)]">
		<Icon class="size-5" strokeWidth={1.8} />
	</div>

	<div class="min-w-0 flex-1">
		<div class="flex items-center gap-2">
			<p class="text-[0.7rem] font-semibold uppercase tracking-[0.18em] text-[var(--color-muted)]">
				{title}
			</p>
			<span class="inline-flex rounded-full bg-[var(--color-surface-subtle)] px-2 py-0.5 text-[0.68rem] font-semibold text-[var(--color-muted)]">
				{external ? 'Extern' : 'Direkt'}
			</span>
		</div>
		<p class="mt-2 text-base font-semibold tracking-[-0.02em] break-words text-[var(--color-text)]">
			{value}
		</p>
	</div>

	<div class="shrink-0 text-[var(--color-muted)] transition-transform group-hover:translate-x-0.5 group-hover:text-[color:var(--color-accent-strong)]">
		{external ? (
			<ArrowUpRight class="size-4" strokeWidth={1.8} />
		) : (
			<ArrowRight class="size-4" strokeWidth={1.8} />
		)}
	</div>
</a>
